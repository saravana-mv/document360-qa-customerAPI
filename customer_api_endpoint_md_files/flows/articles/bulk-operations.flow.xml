<?xml version="1.0" encoding="UTF-8"?>
<flow version="1.0"
      xmlns="https://document360.io/qa/flow/v1"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="https://document360.io/qa/flow/v1 ../flow.xsd">

  <name>Bulk Operations</name>
  <entity>Articles</entity>
  <description>
    Creates a category and article, hides the article using the bulk update
    endpoint, reads it back to confirm the hidden flag changed, then restores
    it to visible — verifying the bulk PATCH endpoint works. Cleans up by
    deleting the article and category.
  </description>
  <stopOnFailure>true</stopOnFailure>

  <steps>

    <step number="1">
      <name>Create Category</name>
      <endpointRef>categories/create-a-category.md</endpointRef>
      <method>POST</method>
      <path>/v2/projects/{project_id}/categories</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
      </pathParams>
      <body><![CDATA[
{
  "name": "[TEST] Bulk Operations - {{timestamp}}",
  "project_version_id": "{{ctx.versionId}}"
}
      ]]></body>
      <captures>
        <capture variable="state.createdCategoryId" source="response.data.id"/>
      </captures>
      <assertions>
        <assertion type="status"       code="201"/>
        <assertion type="field-exists" field="data.id"/>
      </assertions>
    </step>

    <step number="2">
      <name>Create Article</name>
      <endpointRef>articles/create-a-new-article.md</endpointRef>
      <method>POST</method>
      <path>/v3/projects/{project_id}/articles</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
      </pathParams>
      <body><![CDATA[
{
  "title": "[TEST] Bulk Operations - {{timestamp}}",
  "content": "Test article for Bulk Operations flow.",
  "category_id": "{{state.createdCategoryId}}",
  "project_version_id": "{{ctx.versionId}}"
}
      ]]></body>
      <captures>
        <capture variable="state.createdArticleId" source="response.data.id"/>
      </captures>
      <assertions>
        <assertion type="status"       code="201"/>
        <assertion type="field-exists" field="data.id"/>
      </assertions>
    </step>

    <step number="3">
      <name>Bulk Update — Set Hidden</name>
      <endpointRef>articles/bulk-update-articles.md</endpointRef>
      <method>PATCH</method>
      <path>/v3/projects/{project_id}/articles/bulk</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
      </pathParams>
      <body><![CDATA[
{
  "articles": [
    {
      "article_id": "{{state.createdArticleId}}",
      "lang_code": "{{ctx.langCode}}",
      "hidden": true,
      "auto_fork": false
    }
  ]
}
      ]]></body>
      <assertions>
        <assertion type="status"       code="200"/>
        <assertion type="field-equals" field="success" value="true"/>
      </assertions>
    </step>

    <step number="4">
      <name>Verify Article is Hidden</name>
      <endpointRef>articles/get-an-article-by-id.md</endpointRef>
      <method>GET</method>
      <path>/v3/projects/{project_id}/articles/{article_id}</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="article_id">{{state.createdArticleId}}</param>
      </pathParams>
      <queryParams>
        <param name="lang_code">ctx.langCode</param>
      </queryParams>
      <assertions>
        <assertion type="status"       code="200"/>
        <assertion type="field-equals" field="data.hidden" value="true"/>
      </assertions>
    </step>

    <step number="5">
      <name>Bulk Update — Restore Visible</name>
      <endpointRef>articles/bulk-update-articles.md</endpointRef>
      <method>PATCH</method>
      <path>/v3/projects/{project_id}/articles/bulk</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
      </pathParams>
      <body><![CDATA[
{
  "articles": [
    {
      "article_id": "{{state.createdArticleId}}",
      "lang_code": "{{ctx.langCode}}",
      "hidden": false,
      "auto_fork": false
    }
  ]
}
      ]]></body>
      <assertions>
        <assertion type="status"       code="200"/>
        <assertion type="field-equals" field="success" value="true"/>
      </assertions>
      <flags teardown="true"/>
    </step>

    <step number="6">
      <name>Delete Article (cleanup)</name>
      <endpointRef>articles/delete-an-article.md</endpointRef>
      <method>DELETE</method>
      <path>/v3/projects/{project_id}/articles/{article_id}</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="article_id">{{state.createdArticleId}}</param>
      </pathParams>
      <assertions>
        <assertion type="status" code="204"/>
      </assertions>
      <flags teardown="true"/>
    </step>

    <step number="7">
      <name>Delete Category (cleanup)</name>
      <endpointRef>categories/delete-a-category.md</endpointRef>
      <method>DELETE</method>
      <path>/v2/projects/{project_id}/categories/{category_id}</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="category_id">{{state.createdCategoryId}}</param>
      </pathParams>
      <queryParams>
        <param name="project_version_id">ctx.versionId</param>
      </queryParams>
      <assertions>
        <assertion type="status" code="200"/>
      </assertions>
      <flags teardown="true"/>
    </step>

  </steps>
</flow>
