<?xml version="1.0" encoding="UTF-8"?>
<flow version="1.0"
      xmlns="https://document360.io/qa/flow/v1"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="https://document360.io/qa/flow/v1 ../flow.xsd">

  <name>Publish / Unpublish Flow</name>
  <entity>Articles</entity>
  <description>
    Creates a category and article, fetches the article and available
    workflow statuses, transitions the article to a different workflow
    status, then restores the original — verifying the workflow status
    PATCH endpoint works. Cleans up by deleting the article and category.
  </description>
  <stopOnFailure>true</stopOnFailure>

  <steps>

    <step number="1">
      <name>Create Category</name>
      <endpointRef>categories/create-a-category.md</endpointRef>
      <method>POST</method>
      <path>/v2/projects/{project_id}/categories</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
      </pathParams>
      <body><![CDATA[
{
  "name": "[TEST] Publish Flow - {{timestamp}}",
  "project_version_id": "{{ctx.versionId}}"
}
      ]]></body>
      <captures>
        <capture variable="state.createdCategoryId" source="response.data.id"/>
      </captures>
      <assertions>
        <assertion type="status"       code="201"/>
        <assertion type="field-exists" field="data.id"/>
      </assertions>
    </step>

    <step number="2">
      <name>Create Article</name>
      <endpointRef>articles/create-a-new-article.md</endpointRef>
      <method>POST</method>
      <path>/v3/projects/{project_id}/articles</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
      </pathParams>
      <body><![CDATA[
{
  "title": "[TEST] Publish Flow - {{timestamp}}",
  "content": "Test article for Publish / Unpublish Flow.",
  "category_id": "{{state.createdCategoryId}}",
  "project_version_id": "{{ctx.versionId}}"
}
      ]]></body>
      <captures>
        <capture variable="state.createdArticleId" source="response.data.id"/>
      </captures>
      <assertions>
        <assertion type="status"       code="201"/>
        <assertion type="field-exists" field="data.id"/>
      </assertions>
    </step>

    <step number="3">
      <name>Get Article (capture current state)</name>
      <endpointRef>articles/get-an-article-by-id.md</endpointRef>
      <method>GET</method>
      <path>/v3/projects/{project_id}/articles/{article_id}</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="article_id">{{state.createdArticleId}}</param>
      </pathParams>
      <queryParams>
        <param name="lang_code">ctx.langCode</param>
      </queryParams>
      <captures>
        <capture variable="state.projectVersionId"        source="response.data.project_version_id"/>
        <capture variable="state.currentWorkflowStatusId" source="response.data.current_workflow_status_id"/>
      </captures>
      <assertions>
        <assertion type="status" code="200"/>
      </assertions>
    </step>

    <step number="4">
      <name>Get Available Workflow Statuses</name>
      <method>GET</method>
      <path>/v3/projects/{project_id}/workflow-statuses</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
      </pathParams>
      <captures>
        <capture variable="state.workflowStatuses" source="response.data"/>
        <capture variable="state.targetStatusId"
                 source="First entry in response.data where id != state.currentWorkflowStatusId"
                 from="computed"/>
      </captures>
      <assertions>
        <assertion type="status" code="200"/>
      </assertions>
      <flags optional="true"/>
      <notes>
        optional: true — if response.data is empty (project has no workflow
        statuses configured), skip Steps 5 and 6.
      </notes>
    </step>

    <step number="5">
      <name>Transition to New Workflow Status</name>
      <endpointRef>articles/update-workflow-status-for-an-article.md</endpointRef>
      <method>PATCH</method>
      <path>/v3/projects/{project_id}/articles/{article_id}/workflow-status</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="article_id">{{state.createdArticleId}}</param>
      </pathParams>
      <body><![CDATA[
{
  "project_version_id": "{{state.projectVersionId}}",
  "lang_code": "{{ctx.langCode}}",
  "workflow_status_info": {
    "status_id": "{{state.targetStatusId}}"
  }
}
      ]]></body>
      <assertions>
        <assertion type="status" code="200"/>
      </assertions>
      <flags optional="true"/>
    </step>

    <step number="6">
      <name>Restore Original Workflow Status</name>
      <endpointRef>articles/update-workflow-status-for-an-article.md</endpointRef>
      <method>PATCH</method>
      <path>/v3/projects/{project_id}/articles/{article_id}/workflow-status</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="article_id">{{state.createdArticleId}}</param>
      </pathParams>
      <body><![CDATA[
{
  "project_version_id": "{{state.projectVersionId}}",
  "lang_code": "{{ctx.langCode}}",
  "workflow_status_info": {
    "status_id": "{{state.currentWorkflowStatusId}}"
  }
}
      ]]></body>
      <assertions>
        <assertion type="status" code="200"/>
      </assertions>
      <flags teardown="true" optional="true"/>
    </step>

    <step number="7">
      <name>Delete Article (cleanup)</name>
      <endpointRef>articles/delete-an-article.md</endpointRef>
      <method>DELETE</method>
      <path>/v3/projects/{project_id}/articles/{article_id}</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="article_id">{{state.createdArticleId}}</param>
      </pathParams>
      <assertions>
        <assertion type="status" code="204"/>
      </assertions>
      <flags teardown="true"/>
    </step>

    <step number="8">
      <name>Delete Category (cleanup)</name>
      <endpointRef>categories/delete-a-category.md</endpointRef>
      <method>DELETE</method>
      <path>/v2/projects/{project_id}/categories/{category_id}</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="category_id">{{state.createdCategoryId}}</param>
      </pathParams>
      <queryParams>
        <param name="project_version_id">ctx.versionId</param>
      </queryParams>
      <assertions>
        <assertion type="status" code="200"/>
      </assertions>
      <flags teardown="true"/>
    </step>

  </steps>
</flow>
