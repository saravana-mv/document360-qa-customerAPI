<?xml version="1.0" encoding="UTF-8"?>
<flow version="1.0"
      xmlns="https://document360.io/qa/flow/v1"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="https://document360.io/qa/flow/v1 ../flow.xsd">

  <name>Full Article CRUD Lifecycle</name>
  <entity>Articles</entity>
  <description>
    Reads the test article to capture its current title and content,
    applies a timestamped title change to verify the PATCH endpoint works,
    reads back to confirm the change took effect, then restores the
    original title — leaving the article exactly as it was found.
  </description>
  <stopOnFailure>true</stopOnFailure>

  <steps>

    <step number="1">
      <name>Get Single Article</name>
      <endpointRef>articles/get-an-article-by-id.md</endpointRef>
      <method>GET</method>
      <path>/v3/projects/{project_id}/articles/{article_id}</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="article_id">ctx.articleId</param>
      </pathParams>
      <queryParams>
        <param name="lang_code">ctx.langCode</param>
      </queryParams>
      <captures>
        <capture variable="state.originalTitle"   source="response.data.title"/>
        <capture variable="state.originalContent" source="response.data.content"/>
        <capture variable="state.originalArticle" source="response.data"/>
      </captures>
      <assertions>
        <assertion type="status"      code="200"/>
        <assertion type="field-exists" field="data.title"/>
      </assertions>
    </step>

    <step number="2">
      <name>Update Article Title</name>
      <endpointRef>articles/update-an-article.md</endpointRef>
      <method>PATCH</method>
      <path>/v3/projects/{project_id}/articles/{article_id}</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="article_id">ctx.articleId</param>
      </pathParams>
      <queryParams>
        <param name="lang_code">ctx.langCode</param>
      </queryParams>
      <body><![CDATA[
{
  "title": "[TEST] {{state.originalTitle}} - {{timestamp}}",
  "content": "{{state.originalContent}}",
  "auto_fork": true
}
      ]]></body>
      <captures>
        <capture variable="state.testTitle" source="body.title" from="request"/>
      </captures>
      <assertions>
        <assertion type="status" code="200"/>
      </assertions>
      <notes>
        auto_fork: true — if the article version is published, the API automatically
        creates a new draft and applies the update to it. Without this flag,
        updating a published version returns 422.
      </notes>
    </step>

    <step number="3">
      <name>Verify Title Was Updated</name>
      <endpointRef>articles/get-an-article-by-id.md</endpointRef>
      <method>GET</method>
      <path>/v3/projects/{project_id}/articles/{article_id}</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="article_id">ctx.articleId</param>
      </pathParams>
      <queryParams>
        <param name="lang_code">ctx.langCode</param>
      </queryParams>
      <assertions>
        <assertion type="status"       code="200"/>
        <assertion type="field-equals" field="data.title" value="{{state.testTitle}}"/>
      </assertions>
    </step>

    <step number="4">
      <name>Restore Original Title</name>
      <endpointRef>articles/update-an-article.md</endpointRef>
      <method>PATCH</method>
      <path>/v3/projects/{project_id}/articles/{article_id}</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="article_id">ctx.articleId</param>
      </pathParams>
      <queryParams>
        <param name="lang_code">ctx.langCode</param>
      </queryParams>
      <body><![CDATA[
{
  "title": "{{state.originalTitle}}",
  "content": "{{state.originalContent}}",
  "auto_fork": true
}
      ]]></body>
      <assertions>
        <assertion type="status" code="200"/>
      </assertions>
      <flags teardown="true"/>
      <notes>
        teardown: true — this step must run even if Steps 2 or 3 failed,
        to ensure the article is not left with a test title.
      </notes>
    </step>

  </steps>
</flow>
