<?xml version="1.0" encoding="UTF-8"?>
<flow version="1.0"
      xmlns="https://document360.io/qa/flow/v1"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="https://document360.io/qa/flow/v1 ../flow.xsd">

  <name>Full Article CRUD Lifecycle</name>
  <entity>Articles</entity>
  <description>
    Creates a category and article, captures the original title and content,
    applies a timestamped title change to verify the PATCH endpoint works,
    reads back to confirm the change took effect, then restores the
    original title — finally deleting the article and category as teardown.
  </description>
  <stopOnFailure>true</stopOnFailure>

  <steps>

    <step number="1">
      <name>Create Category</name>
      <endpointRef>categories/create-a-category.md</endpointRef>
      <method>POST</method>
      <path>/v2/projects/{project_id}/categories</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
      </pathParams>
      <body><![CDATA[
{
  "name": "[TEST] CRUD Lifecycle - {{timestamp}}",
  "project_version_id": "{{ctx.versionId}}"
}
      ]]></body>
      <captures>
        <capture variable="state.createdCategoryId" source="response.data.id"/>
      </captures>
      <assertions>
        <assertion type="status"       code="201"/>
        <assertion type="field-exists" field="data.id"/>
      </assertions>
    </step>

    <step number="2">
      <name>Create Article</name>
      <endpointRef>articles/create-a-new-article.md</endpointRef>
      <method>POST</method>
      <path>/v3/projects/{project_id}/articles</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
      </pathParams>
      <body><![CDATA[
{
  "title": "[TEST] CRUD Lifecycle - {{timestamp}}",
  "content": "Test article for Full Article CRUD Lifecycle flow.",
  "category_id": "{{state.createdCategoryId}}",
  "project_version_id": "{{ctx.versionId}}"
}
      ]]></body>
      <captures>
        <capture variable="state.createdArticleId" source="response.data.id"/>
      </captures>
      <assertions>
        <assertion type="status"       code="201"/>
        <assertion type="field-exists" field="data.id"/>
      </assertions>
    </step>

    <step number="3">
      <name>Get Single Article</name>
      <endpointRef>articles/get-an-article-by-id.md</endpointRef>
      <method>GET</method>
      <path>/v3/projects/{project_id}/articles/{article_id}</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="article_id">{{state.createdArticleId}}</param>
      </pathParams>
      <queryParams>
        <param name="lang_code">ctx.langCode</param>
      </queryParams>
      <captures>
        <capture variable="state.originalTitle"   source="response.data.title"/>
        <capture variable="state.originalContent" source="response.data.content"/>
        <capture variable="state.originalArticle" source="response.data"/>
      </captures>
      <assertions>
        <assertion type="status"       code="200"/>
        <assertion type="field-exists" field="data.title"/>
      </assertions>
    </step>

    <step number="4">
      <name>Update Article Title</name>
      <endpointRef>articles/update-an-article.md</endpointRef>
      <method>PATCH</method>
      <path>/v3/projects/{project_id}/articles/{article_id}</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="article_id">{{state.createdArticleId}}</param>
      </pathParams>
      <queryParams>
        <param name="lang_code">ctx.langCode</param>
      </queryParams>
      <body><![CDATA[
{
  "title": "[TEST] {{state.originalTitle}} - {{timestamp}}",
  "content": "{{state.originalContent}}",
  "auto_fork": true
}
      ]]></body>
      <captures>
        <capture variable="state.testTitle" source="body.title" from="request"/>
      </captures>
      <assertions>
        <assertion type="status" code="200"/>
      </assertions>
    </step>

    <step number="5">
      <name>Verify Title Was Updated</name>
      <endpointRef>articles/get-an-article-by-id.md</endpointRef>
      <method>GET</method>
      <path>/v3/projects/{project_id}/articles/{article_id}</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="article_id">{{state.createdArticleId}}</param>
      </pathParams>
      <queryParams>
        <param name="lang_code">ctx.langCode</param>
      </queryParams>
      <assertions>
        <assertion type="status"       code="200"/>
        <assertion type="field-equals" field="data.title" value="{{state.testTitle}}"/>
      </assertions>
    </step>

    <step number="6">
      <name>Delete Article (cleanup)</name>
      <endpointRef>articles/delete-an-article.md</endpointRef>
      <method>DELETE</method>
      <path>/v3/projects/{project_id}/articles/{article_id}</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="article_id">{{state.createdArticleId}}</param>
      </pathParams>
      <assertions>
        <assertion type="status" code="204"/>
      </assertions>
      <flags teardown="true"/>
      <notes>
        teardown: true — always runs to delete the test article even if
        earlier steps failed. Must run before category deletion.
      </notes>
    </step>

    <step number="7">
      <name>Delete Category (cleanup)</name>
      <endpointRef>categories/delete-a-category.md</endpointRef>
      <method>DELETE</method>
      <path>/v2/projects/{project_id}/categories/{category_id}</path>
      <pathParams>
        <param name="project_id">ctx.projectId</param>
        <param name="category_id">{{state.createdCategoryId}}</param>
      </pathParams>
      <queryParams>
        <param name="project_version_id">ctx.versionId</param>
      </queryParams>
      <assertions>
        <assertion type="status" code="200"/>
      </assertions>
      <flags teardown="true"/>
      <notes>
        teardown: true — runs after article deletion to clean up the category.
      </notes>
    </step>

  </steps>
</flow>
